		{"id":"9d4961c00b124c62","type":"file","file":"TES3 Plugins/OAAB_Grazelands/Topic/a new mouth for Aryon/a new mouth for Aryon ~5.md","subpath":"#^obsidian-esp-canvas-808da37e29","x":2825,"y":1199,"width":440,"height":282,"color":"3"},
		{"id":"540235bfe89cbad5","type":"text","text":"Disposition = 0\nPC Faction = Telvanni\nPC Rank = Rank 5\nID = galos mathendis\nJournal - OAAB_TVos_GalosMouth <= 10","x":2260,"y":1201,"width":385,"height":146,"color":"4"},
		{"id":"1707072660258460","type":"text","text":"\"You need me to track her down?\" - Choice 1","x":3445,"y":1022,"width":320,"height":74,"color":"4"},
		{"id":"2c8c71e7b9d48989","type":"text","text":"\"I'm sorry, Galos, I don't have time for a wild goose chase. Aryon will just have to wait.\" - Choice 2","x":3445,"y":1605,"width":320,"height":98,"color":"4"},
		{"id":"ad47537dfe87cda3","type":"file","file":"TES3 Plugins/OAAB_Grazelands/Topic/a new mouth for Aryon/a new mouth for Aryon ~4.md","subpath":"#^obsidian-esp-canvas-c0fbf0638a","x":6435,"y":708,"width":440,"height":210,"color":"3"},
		{"id":"53944d9af5f6e084","type":"text","text":"Disposition = 0\nPC Faction = Telvanni\nPC Rank = Rank 5\nID = galos mathendis\nChoice = 1\nJournal - OAAB_TVos_GalosMouth <= 10","x":5870,"y":841,"width":385,"height":170,"color":"4"},
		{"id":"790a8fd8078fa542","type":"text","text":"AddTopic \"[[Reynel Uvirith]]\"\nJournal [[OAAB_TVos_GalosMouth 20#^obsidian-esp-canvas-f7420d21d3|OAAB_TVos_GalosMouth 20]]","x":6435,"y":948,"width":440,"height":98,"color":"6"},
		{"id":"ce1a0e7e6d514d24","type":"file","file":"TES3 Plugins/OAAB_Grazelands/Topic/a new mouth for Aryon/a new mouth for Aryon ~3.md","subpath":"#^obsidian-esp-canvas-4fbcf6c0d4","x":4630,"y":1835,"width":440,"height":162,"color":"3"},
		{"id":"f557a201c872a503","type":"text","text":"Disposition = 0\nPC Faction = Telvanni\nPC Rank = Rank 5\nID = galos mathendis\nChoice = 2\nJournal - OAAB_TVos_GalosMouth <= 10","x":4065,"y":1726,"width":385,"height":170,"color":"4"},
		{"id":"78bccacec117ccae","type":"text","text":"\"*Sigh* Very well, Galos. Where do I start?\" - Choice 1","x":5250,"y":1271,"width":320,"height":74,"color":"4"},
		{"id":"59958ff782d1043b","type":"text","text":"\"I wasn't born yesterday, Galos. Aryon did what he did toward his own ends. If I hadn't conveniently arrived, someone else would have served his purposes.\" - Choice 3","x":5250,"y":2539,"width":320,"height":146,"color":"4"},
		{"id":"7fdf1d00fcdda82e","type":"file","file":"TES3 Plugins/OAAB_Grazelands/Greeting/Greeting 2/Greeting 2 ~10.md","subpath":"#^obsidian-esp-canvas-3124dd466f","x":1640,"y":-574,"width":440,"height":114,"color":"3"},
		{"id":"8fe5d33fb5c17489","type":"text","text":"Disposition = 0\nID = ABtv_ReynelUvirith\nJournal - OAAB_TVos_GalosMouth <= 50","x":1180,"y":-208,"width":385,"height":98,"color":"4"},
		{"id":"453e08519504f7e5","type":"text","text":"\"You know my name?\" - Choice 1","x":2260,"y":-910,"width":320,"height":50,"color":"4"},
		{"id":"c1fe6dd6a0898e5e","type":"text","text":"\"I have a proposition from Master Aryon.\" - Choice 2","x":2260,"y":-366,"width":320,"height":74,"color":"4"},
		{"id":"b821ae5ac4584202","type":"file","file":"TES3 Plugins/OAAB_Grazelands/Greeting/Greeting 2/Greeting 2 ~9.md","subpath":"#^obsidian-esp-canvas-b197db9c23","x":3445,"y":-1209,"width":440,"height":96,"color":"3"},
		{"id":"cc5031af0dd86889","type":"text","text":"Disposition = 0\nID = ABtv_ReynelUvirith\nChoice = 1\nJournal - OAAB_TVos_GalosMouth <= 50","x":2825,"y":-1130,"width":385,"height":122,"color":"4"},
		{"id":"be4851ced54e0bce","type":"text","text":"\"I have a proposition from Master Aryon.\" - Choice 2","x":4065,"y":-1264,"width":320,"height":74,"color":"4"},
		{"id":"b88f967f52543dc3","type":"file","file":"TES3 Plugins/OAAB_Grazelands/Greeting/Greeting 2/Greeting 2 ~8.md","subpath":"#^obsidian-esp-canvas-4ebb6aa977","x":5250,"y":-1286,"width":440,"height":114,"color":"3"},
		{"id":"c450b98a54d6cb08","type":"text","text":"Disposition = 0\nID = ABtv_ReynelUvirith\nChoice = 2\nJournal - OAAB_TVos_GalosMouth <= 50","x":4630,"y":-1242,"width":385,"height":122,"color":"4"},
		{"id":"e606de7f8caefd41","type":"text","text":"\"Be reasonable, Reynel. This is a good opportunity.\" - Choice 3","x":5870,"y":-1740,"width":320,"height":74,"color":"4"},
		{"id":"fe5223ad4965e289","type":"text","text":"\"Fine, don't accept then.\" - Choice 4","x":5870,"y":-815,"width":320,"height":74,"color":"4"},
		{"id":"874eda29e790970d","type":"file","file":"TES3 Plugins/OAAB_Grazelands/Greeting/Greeting 2/Greeting 2 ~6.md","subpath":"#^obsidian-esp-canvas-7ffc26ff03","x":7055,"y":-2199,"width":440,"height":162,"color":"3"},
		{"id":"f65a564c5ef40b76","type":"text","text":"Disposition = 0\nID = ABtv_ReynelUvirith\nChoice = 3\nJournal - OAAB_TVos_GalosMouth <= 50","x":6435,"y":-2002,"width":385,"height":122,"color":"4"},
		{"id":"03eb90c85775915a","type":"text","text":"\"Very well, I wish you luck.\" - Choice 5","x":7675,"y":-2390,"width":320,"height":74,"color":"4"},
		{"id":"b9c13181aff0133b","type":"text","text":"\"I'm sure Master Aryon can undo anything you have begun.\" - Choice 6","x":7675,"y":-2180,"width":320,"height":74,"color":"4"},
		{"id":"39f2027befd35995","type":"text","text":"\"Do you truly believe House Redoran will ever see you as anything but a Telvanni spy?\" - Choice 7","x":7675,"y":-1830,"width":320,"height":98,"color":"4"},
		{"id":"d9092986cd94267e","type":"file","file":"TES3 Plugins/OAAB_Grazelands/Greeting/Greeting 2/Greeting 2 ~5.md","subpath":"#^obsidian-esp-canvas-7af9bc801a","x":8860,"y":-2532,"width":440,"height":96,"color":"3"},
		{"id":"2b0d5a7b6e2b4745","type":"text","text":"Disposition = 0\nID = ABtv_ReynelUvirith\nChoice = 5\nJournal - OAAB_TVos_GalosMouth <= 50","x":8240,"y":-2545,"width":385,"height":122,"color":"4"},
		{"id":"02ea71bd5f9c24bb","type":"text","text":"ModDisposition -10\nGoodbye","x":8860,"y":-2406,"width":440,"height":74,"color":"5"},
		{"id":"dedc578bc03a00cf","type":"file","file":"TES3 Plugins/OAAB_Grazelands/Greeting/Greeting 2/Greeting 2 ~4.md","subpath":"#^obsidian-esp-canvas-8af9413d02","x":8860,"y":-2125,"width":440,"height":138,"color":"3"},
		{"id":"5e4864f64bd6bdf4","type":"text","text":"Disposition = 0\nID = ABtv_ReynelUvirith\nChoice = 6\nJournal - OAAB_TVos_GalosMouth <= 50","x":8240,"y":-2263,"width":385,"height":122,"color":"4"},
		{"id":"25bc6154b11962ae","type":"text","text":"\"Aryon has influence, just look at how quickly I have risen under his guidance.\" - Choice 8","x":9480,"y":-2015,"width":320,"height":98,"color":"4"},
		{"id":"b65b6945831f67d9","type":"file","file":"TES3 Plugins/OAAB_Grazelands/Greeting/Greeting 2/Greeting 2 ~2.md","subpath":"#^obsidian-esp-canvas-eeb31f2339","x":8860,"y":-1827,"width":440,"height":138,"color":"3"},
		{"id":"ba1e12b8eb1a08b2","type":"text","text":"Disposition = 0\nID = ABtv_ReynelUvirith\nChoice = 7\nDead - bolvyn venim = 1\nJournal - OAAB_TVos_GalosMouth <= 50","x":8240,"y":-1981,"width":385,"height":146,"color":"4"},
		{"id":"b8cf85900b92286a","type":"text","text":"\"With House Redoran in chaos over Bolvyn Venim's death, you have no chance of swaying general opinions. You'll always be under suspicion.\" - Choice 8","x":9480,"y":-1758,"width":320,"height":146,"color":"4"},
		{"id":"aded748821c40758","type":"file","file":"TES3 Plugins/OAAB_Grazelands/Greeting/Greeting 2/Greeting 2 ~3.md","subpath":"#^obsidian-esp-canvas-abca693ee7","x":8860,"y":-1529,"width":440,"height":138,"color":"3"},
		{"id":"ca1c0475d0bc4173","type":"text","text":"Disposition = 0\nID = ABtv_ReynelUvirith\nChoice = 7\nDead - bolvyn venim = 0\nJournal - OAAB_TVos_GalosMouth <= 50","x":8240,"y":-1675,"width":385,"height":146,"color":"4"},
		{"id":"8d31ad8541b5fdc1","type":"text","text":"\"With Bolvyn Venim as their Archmaster, you have no chance of swaying general opinions. You'll always be under suspicion.\" - Choice 8","x":9480,"y":-1466,"width":320,"height":122,"color":"4"},
