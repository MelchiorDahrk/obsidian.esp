		{"id":"bb33f8c5e81d8c37","type":"text","text":"\"Get them yourself, Dreynos. I got you the information you asked for. I'm not risking my life for your root problem.\" - Choice 5","x":9340,"y":-1446,"width":320,"height":122,"color":"4"},
		{"id":"9046c5e9cae15d5d","type":"text","text":"\"How are you going to make this worth my while?\" - Choice 6","x":9340,"y":-1272,"width":320,"height":74,"color":"4"},
		{"id":"f1f626414f067e4f","type":"text","text":"\"I have it already.\" - Choice 10","x":9340,"y":-1769,"width":320,"height":50,"color":"4"},
		{"id":"c5424f5bf035eb6d","type":"file","file":"TES3 Plugins/OAAB_Grazelands/Topic/mushroom roots from Tel Vos/mushroom roots from Tel Vos ~28.md","subpath":"#^obsidian-esp-canvas-bf3efe299c","x":10300,"y":-2074,"width":440,"height":186,"color":"3"},
		{"id":"11c175ce58b6fe36","type":"text","text":"Disposition = 0\nID = dreynos elvul\nChoice = 10\nJournal - OAAB_TVos_RootOfTheProblem = 30","x":9840,"y":-1999,"width":385,"height":122,"color":"4"},
		{"id":"f3357b04a7ca3770","type":"text","text":"Player->RemoveItem \"AB_IngCrea_KwamaPoison\" 3\nJournal [[OAAB_TVos_RootOfTheProblem 90#^obsidian-esp-canvas-8dc02f8cc1|OAAB_TVos_RootOfTheProblem 90]]\nStartScript ABtv_RootProblemWait_s","x":10300,"y":-1858,"width":440,"height":146,"color":"6"},
		{"id":"5e87416aab471c40","type":"file","file":"TES3 Plugins/OAAB_Grazelands/Topic/mushroom roots from Tel Vos/mushroom roots from Tel Vos ~25.md","subpath":"#^obsidian-esp-canvas-eb7d500038","x":14020,"y":-765,"width":440,"height":114,"color":"3"},
		{"id":"0061b2f7b53f234b","type":"text","text":"Disposition = 0\nID = dreynos elvul\nChoice = 7\nJournal - OAAB_TVos_RootOfTheProblem = 30","x":13400,"y":-769,"width":385,"height":122,"color":"4"},
		{"id":"8f0abb155a9ee5dd","type":"text","text":"Goodbye","x":14020,"y":-621,"width":440,"height":50,"color":"5"},
		{"id":"c5ff28d1b319c457","type":"file","file":"TES3 Plugins/OAAB_Grazelands/Topic/mushroom roots from Tel Vos/mushroom roots from Tel Vos ~22.md","subpath":"#^obsidian-esp-canvas-5f36b2a304","x":12160,"y":-563,"width":440,"height":138,"color":"3"},
		{"id":"d5141a6cb622c38c","type":"text","text":"Disposition = 0\nID = dreynos elvul\nChoice = 5\nJournal - OAAB_TVos_RootOfTheProblem = 30","x":11540,"y":-648,"width":385,"height":122,"color":"4"},
		{"id":"cecc3942ef6ce4f8","type":"text","text":"\"Very well. The artifact will be enough.\" - Choice 7","x":12780,"y":-511,"width":320,"height":74,"color":"4"},
		{"id":"f3691123e47d4faf","type":"text","text":"\"Then forget it.\" - Choice 4","x":12780,"y":-413,"width":320,"height":50,"color":"4"},
		{"id":"c6015044a3f843a6","type":"file","file":"TES3 Plugins/OAAB_Grazelands/Topic/mushroom roots from Tel Vos/mushroom roots from Tel Vos ~23.md","subpath":"#^obsidian-esp-canvas-1c4dfcbef4","x":10300,"y":-903,"width":440,"height":138,"color":"3"},
		{"id":"ff7bd4b91e76497d","type":"text","text":"Disposition = 0\nID = dreynos elvul\nChoice = 6\nJournal - OAAB_TVos_RootOfTheProblem = 30\nPcSpeechcraft < 70","x":9840,"y":-1058,"width":385,"height":146,"color":"4"},
		{"id":"ee9117f9728315c5","type":"text","text":"\"That will do.\" - Choice 7","x":10920,"y":-1140,"width":320,"height":50,"color":"4"},
		{"id":"87c5526a6f955a70","type":"text","text":"\"That's not good enough.\" - Choice 5","x":10920,"y":-619,"width":320,"height":74,"color":"4"},
		{"id":"6685268ffecf3441","type":"file","file":"TES3 Plugins/OAAB_Grazelands/Topic/mushroom roots from Tel Vos/mushroom roots from Tel Vos ~24.md","subpath":"#^obsidian-esp-canvas-fb7cd4bdf1","x":10300,"y":-1455,"width":440,"height":138,"color":"3"},
		{"id":"fade36d253e3c2ca","type":"text","text":"Disposition = 0\nID = dreynos elvul\nChoice = 6\nJournal - OAAB_TVos_RootOfTheProblem = 30\nPcSpeechcraft >= 70","x":9840,"y":-1534,"width":385,"height":146,"color":"4"},
		{"id":"d3a1f40835ed3d7e","type":"text","text":"\"That will do.\" - Choice 7","x":10920,"y":-1337,"width":320,"height":50,"color":"4"},
		{"id":"146e32db91f89bc7","type":"text","text":"\"[Speechcraft] Surely the prospect of losing your house to the roots is enough motivation to offer a greater reward.\" - Choice 8","x":10920,"y":-1483,"width":320,"height":122,"color":"4"},
		{"id":"3736d3cd5af99223","type":"file","file":"TES3 Plugins/OAAB_Grazelands/Topic/mushroom roots from Tel Vos/mushroom roots from Tel Vos ~26.md","subpath":"#^obsidian-esp-canvas-f07fba7fa0","x":12160,"y":-1476,"width":440,"height":138,"color":"3"},
		{"id":"98d643d84e99bdc8","type":"text","text":"Disposition = 0\nID = dreynos elvul\nChoice = 8\nJournal - OAAB_TVos_RootOfTheProblem = 30","x":11540,"y":-1473,"width":385,"height":122,"color":"4"},
		{"id":"e114bc52b26cf7ce","type":"text","text":"ModDisposition -5","x":12160,"y":-1308,"width":440,"height":50,"color":"5"},
		{"id":"5f2aa451a7cd8cb7","type":"text","text":"\"It's a deal, but you'll give it to me now -- in advance.\" - Choice 9","x":12780,"y":-1447,"width":320,"height":98,"color":"4"},
